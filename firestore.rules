rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: barcode (string)
    // Fields:
    //   - barcode: string (required)
    //   - name: string (required, 1-100 chars)
    //   - price: number (required, >= 0)
    //   - stock_quantity: int (required, >= 0)
    //   - tax_rate: number (optional, >= 0)
    //
    // Collection: sales
    // Document ID: invoice_id (string)
    // Fields:
    //   - invoice_id: string (required)
    //   - timestamp: string (required, ISO 8601)
    //   - total_amount: number (required, >= 0)
    //   - payment_method: string (required, enum: cash, card, upi)
    //   - items: list (required, max 100 items)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "jebinanthony2007@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProduct(data) {
      return hasRequiredFields(['barcode', 'name', 'price', 'stock_quantity']) &&
             hasOnlyAllowedFields(['barcode', 'name', 'price', 'stock_quantity', 'tax_rate']) &&
             data.barcode is string && data.barcode.size() > 0 && data.barcode.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.stock_quantity is int &&
             (!('tax_rate' in data) || (data.tax_rate is number && data.tax_rate >= 0));
    }

    function isValidSale(data) {
      return hasRequiredFields(['invoice_id', 'timestamp', 'total_amount', 'payment_method', 'items']) &&
             hasOnlyAllowedFields(['invoice_id', 'timestamp', 'total_amount', 'payment_method', 'items']) &&
             data.invoice_id is string &&
             data.timestamp is string &&
             data.total_amount is number && data.total_amount >= 0 &&
             data.payment_method in ['cash', 'card', 'upi'] &&
             data.items is list && data.items.size() <= 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{barcode} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sales/{invoice_id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSale(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
